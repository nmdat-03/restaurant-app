{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate --schema=../prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate --schema=../prisma/schema.prisma",
    "db:generate": "prisma generate --schema=../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
    "db:seed": "prisma db seed --schema=../prisma/schema.prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma"
    ]
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.0.1",
    "next": "15.5.14",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "qs": "^6.15.1",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.0",
    "react-select": "^5.10.2",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "svix": "^1.89.0",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qs": "^6.15.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
